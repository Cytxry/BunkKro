{
  "manifest_version": 3,
  "name": "BunkKro Attendance Tracker",
  "version": "1.0.0",
  "description": "Quick attendance tracking from your browser",
  
  "permissions": [
    "storage"
  ],
  
  "host_permissions": [
    "https://bunkkro.vercel.app/*",
    "https://mvlyeygitnnuksuxmcsy.supabase.co/*"
  ],
  
  "background": {
    "service_worker": "background.js"
  },
  
 "content_scripts": [
    {
      "matches": ["https://bunkkro.vercel.app/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}